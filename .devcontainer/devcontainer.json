{
  "name": "HTML & CSS Starter with AI Mentor",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  "customizations": {
    "vscode": {
      "extensions": [
        "ritwickdey.LiveServer",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {}
    }
  },
  "portsAttributes": {
    "5500": {
      "label": "Live Server",
      "onAutoForward": "openBrowser"
    }
  }
}
